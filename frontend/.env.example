EXPO_PUBLIC_API_URL=http://localhost:9000/api/v1

# Google OAuth client IDs from Google Cloud Console -> APIs & Services -> Credentials.
# Create three OAuth 2.0 client IDs (iOS, Android, Web) and paste them below.
# The Web client ID is what @react-native-google-signin uses to request an ID token.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
